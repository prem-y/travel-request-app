<mvc:View controllerName="com.travel.request.travelrequest.controller.App"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:t="sap.tnt">

    <t:ToolPage id="toolPage">

        <!-- LEFT DRAWER -->
        <t:sideContent>
            <t:SideNavigation id="sideNavigation" itemSelect=".onNavItemSelect">
                <t:NavigationList id="navList">
                    <t:NavigationListItem
                        id="navDashboard"
                        text="Dashboard"
                        icon="sap-icon://home"
                        key="dashboard"/>
                    <t:NavigationListItem
                        id="navItem2"
                        text="Employee View"
                        icon="sap-icon://employee"
                        key="employee"/>
                    <t:NavigationListItem
                        id="navItem3"
                        text="Manager View"
                        icon="sap-icon://manager"
                        key="manager"
                        visible="false"/>
                    <t:NavigationListItem
                        id="navItem4"
                        text="Finance View"
                        icon="sap-icon://money-bills"
                        key="finance"
                        visible="false"/>
                </t:NavigationList>
            </t:SideNavigation>
        </t:sideContent>

        <!-- TOP APP BAR -->
        <t:header>
            <t:ToolHeader id="toolHeader">
                <Button
                    id="menuToggleBtn"
                    icon="sap-icon://menu2"
                    press=".onToggleSideNav"
                    type="Transparent"/>
                <Title
                    id="appTitle"
                    text="Travel Request App"
                    titleStyle="H4"
                    class="sapUiSmallMarginBegin"/>
                <Text
                    id="moduleLabel"
                    text=""
                    class="sapUiSmallMarginBegin sapThemeHighlight-asColor"/>
                <ToolbarSpacer id="toolbarSpacer"/>
                <Button
                    id="moduleSwitchBtn"
                    icon="sap-icon://grid"
                    type="Transparent"
                    tooltip="Switch Module"
                    press=".onModuleSwitchPress"/>
                <Avatar
                    id="userAvatar"
                    initials="{session>/initials}"
                    displaySize="XS"
                    backgroundColor="Accent6"/>
            </t:ToolHeader>
        </t:header>

        <!-- MAIN CONTENT AREA -->
        <t:mainContents>
            <NavContainer id="mainNavContainer">
            </NavContainer>
        </t:mainContents>

    </t:ToolPage>

</mvc:View>