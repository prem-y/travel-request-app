<mvc:View
    controllerName="com.travel.request.travelrequest.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <VBox id="dashboardRoot" class="sapUiMediumMargin">

        <Title id="dashboardTitle" text="Dashboard" titleStyle="H2" class="sapUiMediumMarginBottom"/>

        <FlexBox id="kpiTilesBox" wrap="Wrap" alignItems="Start">

            <!-- Total Requests -->
            <GenericTile id="tileTotalRequests"
                header="Total Requests"
                subheader="All submitted requests"
                frameType="OneByOne"
                class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                <tileContent>
                    <TileContent id="tcTotal">
                        <content>
                            <NumericContent
                                id="ncTotal"
                                value="{kpiModel>/total}"
                                icon="sap-icon://travel-request"
                                valueColor="Neutral"/>
                        </content>
                    </TileContent>
                </tileContent>
            </GenericTile>

            <!-- Pending Approval -->
            <GenericTile id="tilePending"
                header="Pending Approval"
                subheader="Awaiting manager review"
                frameType="OneByOne"
                class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                <tileContent>
                    <TileContent id="tcPending">
                        <content>
                            <NumericContent
                                id="ncPending"
                                value="{kpiModel>/pending}"
                                icon="sap-icon://pending"
                                valueColor="Critical"/>
                        </content>
                    </TileContent>
                </tileContent>
            </GenericTile>

            <!-- Approved -->
            <GenericTile id="tileApproved"
                header="Approved"
                subheader="Successfully approved"
                frameType="OneByOne"
                class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                <tileContent>
                    <TileContent id="tcApproved">
                        <content>
                            <NumericContent
                                id="ncApproved"
                                value="{kpiModel>/approved}"
                                icon="sap-icon://accept"
                                valueColor="Good"/>
                        </content>
                    </TileContent>
                </tileContent>
            </GenericTile>

            <!-- Rejected -->
            <GenericTile id="tileRejected"
                header="Rejected"
                subheader="Declined requests"
                frameType="OneByOne"
                class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                <tileContent>
                    <TileContent id="tcRejected">
                        <content>
                            <NumericContent
                                id="ncRejected"
                                value="{kpiModel>/rejected}"
                                icon="sap-icon://decline"
                                valueColor="Error"/>
                        </content>
                    </TileContent>
                </tileContent>
            </GenericTile>

        </FlexBox>
    </VBox>

</mvc:View>